# FluxBase BotSeller - Vercel Environment Variables
# Nie wklejaj prawdziwych sekretów do GitHuba. Ustaw je w Vercel → Settings → Environment Variables.

# --- Publiczne URL-e ---
NEXT_PUBLIC_SITE_URL=https://www.fluxbase.pl
NEXT_PUBLIC_BASE_URL=https://www.fluxbase.pl

# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# --- Admin / bezpieczeństwo ---
ADMIN_EMAILS=office@fluxbase.pl,julianrutkowski026@gmail.com
CRON_SECRET=GENERATE_LONG_RANDOM_SECRET
SECRET_ENCRYPTION_KEY=BASE64_32_BYTES_KEY
CLIENT_PORTAL_SECRET=GENERATE_LONG_RANDOM_SECRET

# --- OpenAI ---
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL=gpt-5.5

# --- Google lead search ---
GOOGLE_PLACES_API_KEY=YOUR_GOOGLE_PLACES_API_KEY
GOOGLE_SEARCH_API_KEY=YOUR_GOOGLE_SEARCH_API_KEY
GOOGLE_SEARCH_CX=YOUR_GOOGLE_CUSTOM_SEARCH_ENGINE_ID
# Alternatywnie zamiast GOOGLE_SEARCH_CX możesz ustawić:
# GOOGLE_SEARCH_ENGINE_ID=YOUR_GOOGLE_CUSTOM_SEARCH_ENGINE_ID

# --- Stripe ---
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_POLAND_STARTER=price_...
STRIPE_PRICE_POLAND_GROWTH=price_...
STRIPE_PRICE_POLAND_PRO=price_...
STRIPE_PRICE_EUROPE_SCALE=price_...
STRIPE_PRICE_ADDITIONAL_MAILBOX=price_...

# --- Globalne bezpieczniki aplikacji ---
APP_MAX_ACTIVE_CAMPAIGNS=12
APP_MAX_DAILY_EMAILS=600
APP_MAX_MONTHLY_EMAILS=12000
APP_MAX_PENDING_QUEUE=300
APP_MAX_FAILED_QUEUE=30
SEND_WORKER_BATCH_SIZE=1
SEND_QUEUE_MAX_ATTEMPTS=3
SEND_QUEUE_STALE_LOCK_MINUTES=15

# --- Reputacja wysyłki ---
REPUTATION_MIN_SAMPLE=20
REPUTATION_MAX_BOUNCE_RATE=8
REPUTATION_MAX_SPAM_RATE=1
REPUTATION_MAX_FAILED_RATE=25

# --- Publiczny test SMTP / fallback SMTP, jeśli używasz ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=example@domain.pl
SMTP_PASS=app_password
SMTP_FROM=example@domain.pl

# --- Email provider webhooks / opcjonalnie ---
EMAIL_EVENTS_SECRET=GENERATE_LONG_RANDOM_SECRET
POSTMARK_WEBHOOK_TOKEN=
MAILGUN_WEBHOOK_SIGNING_KEY=
SENDGRID_WEBHOOK_SECRET=
